                        class="flex items-center gap-4 text-sm text-gray-700 hover:text-brand-burgundy transition-colors group">
                        <div
                            class="w-12 h-12 bg-brand-cream rounded-full flex items-center justify-center group-hover:bg-brand-burgundy transition-colors"> <i data-lucide="phone"
                                class="w-5 h-5 text-brand-burgundy group-hover:text-white transition-colors" stroke-width="1.5"></i>
                        </div>
                        <div>
                            <div data-editable="text" data-prop="cta.phone_label" class="font-medium">{{ cta.phone_label }}</div> <div data-editable="text" data-prop="cta.phone_value" class="text-xs text-gray-400">{{ cta.phone_value }}</div>
                        </div>
                    </a>
                </div>
            </div>
            <div class="relative w-full max-w-md ml-auto fade-in">
                <div
                    class="absolute -left-4 md:-left-6 bottom-[-16px] md:bottom-[-24px] w-2/3 h-4 bg-brand-burgundy z-20 rounded-sm">
                </div>
                <img data-editable="image" data-prop-src="cta.image" src="{{ cta.image }}" alt="Michaela stylistka"
                    class="relative z-10 w-full object-cover object-top aspect-[3/4]" id="cta-image" loading="lazy" decoding="async">
            </div>
        </section>

        <!-- Instagram Section -->
        <section id="instagram" class="bg-brand-cream py-24 md:py-32"> <div class="max-w-7xl mx-auto px-6">
                <div class="text-center mb-12 fade-in"> <p data-editable="text" data-prop="instagram.tag" class="text-brand-burgundy text-sm tracking-widest uppercase font-medium mb-4">{{ instagram.tag }}</p>
                    <h2 data-editable="text" data-prop="instagram.title" class="font-serif text-3xl md:text-4xl lg:text-5xl tracking-tight mb-4">{{ instagram.title }}</h2> <p data-editable="text" data-prop="instagram.description" class="text-gray-600">{{ instagram.description }}</p>
                </div>
                <div data-editable="array" data-prop="instagram.items" class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mb-12 fade-in">
                    {% for item in instagram.items %}
                    <a data-editable="array-item" href="{{ item.link }}" target="_blank" class="aspect-[4/5] bg-brand-warm rounded-sm overflow-hidden group block"> <img data-editable="image" data-prop-src="image" src="{{ item.image }}"
                            alt="{{ item.alt }}"
                            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" decoding="async">
                    </a>
                    {% endfor %}
                </div>
                <div class="text-center fade-in"> <a href="{{ instagram.btn_link }}" target="_blank"
                        class="border border-brand-burgundy text-brand-burgundy px-8 py-3.5 text-sm font-medium hover:bg-brand-burgundy hover:text-white transition-all inline-flex items-center gap-3 rounded-sm"> <i data-lucide="instagram" class="w-4 h-4" stroke-width="1.5"></i>
                        {{ instagram.btn_text }}
                    </a>
                </div>
            </div>
        </section>

    </main>

    <!-- Footer -->
    <footer class="bg-brand-text text-white/60 py-16"> <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-center gap-8 mb-10"> <div data-editable="text" data-prop="footer.name" class="font-serif text-3xl text-white italic tracking-tight">{{ footer.name }}</div>

                <nav class="flex flex-wrap justify-center gap-6 md:gap-8 text-xs font-light tracking-wide uppercase" aria-label="Patičková navigace">
                    <a href="#o-mne" class="hover:text-white transition-colors">O mně</a> <a href="#sluzby" class="hover:text-white transition-colors">Služby</a> <a href="#recenze" class="hover:text-white transition-colors">Recenze</a> <a href="#jak-to-funguje" class="hover:text-white transition-colors">Jak to funguje</a> <a href="#instagram" class="hover:text-white transition-colors">Instagram</a>
                </nav>

                <div class="flex flex-col items-center md:items-end gap-2 text-xs font-light"> <a href="{{ footer.instagram_link }}" target="_blank"
                        class="hover:text-white transition-colors flex items-center gap-2"> <i data-lucide="instagram" class="w-4 h-4" stroke-width="1.5"></i>
                        {{ footer.instagram_label }}
                    </a>
                    <a data-editable="text" data-prop="footer.email" href="mailto:{{ footer.email }}"
                        class="hover:text-white transition-colors">{{ footer.email }}</a> <a data-editable="text" data-prop="footer.phone" href="tel:{{ footer.phone | replace(' ', '') }}" class="hover:text-white transition-colors">{{ footer.phone }}</a>
                </div>
            </div>
            <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4"> <p data-editable="text" data-prop="footer.copyright" class="text-xs">{{ footer.copyright }}</p>
                <p data-editable="text" data-prop="footer.slogan" class="text-xs text-white/30">{{ footer.slogan }}</p>
            </div>
        </div>
    </footer>

    <script>
        // Initialize Lucide icons (wait for deferred script)
        document.addEventListener('DOMContentLoaded', () => lucide.createIcons());

        // Mobile menu toggle
        const menuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        if (menuToggle && mobileMenu) {
            menuToggle.addEventListener('click', () => {
                mobileMenu.classList.toggle('open');
            });
            // Close mobile menu when clicking a link
            mobileMenu.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenu.classList.remove('open');
                });
            });
        }

        // Scroll-triggered fade-in animations
        const fadeElements = document.querySelectorAll('.fade-in');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
        fadeElements.forEach(el => observer.observe(el));
    </script>

</body>

</html>
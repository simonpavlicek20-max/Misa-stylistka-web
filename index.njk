    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://images.unsplash.com">
    <link rel="preconnect" href="https://unpkg.com">
    <link rel="preconnect" href="https://cdn.tailwindcss.com">

    <script src="https://cdn.tailwindcss.com"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap"
        rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest" defer></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            burgundy: '#7A2E3A',
                            dark: '#5C1E2A',
                            cream: '#FAF7F2',
                            warm: '#F3EDE4',
                            gold: '#C9A96E',
                            text: '#2D2926',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .font-serif {
            font-family: 'Playfair Display', serif;
        }

        @keyframes marquee {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-50%);
            }
        }

        .animate-marquee {
            animation: marquee 25s linear infinite;
        }

        /* Smooth scroll */
        html {
            scroll-behavior: smooth;
        }

        /* Fade-in on scroll */
        .fade-in {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }

        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* Service card hover */
        .service-card {
            transition: transform 0.4s ease, box-shadow 0.4s ease;
        }

        .service-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 60px rgba(122, 46, 58, 0.12);
        }

        /* Button hover glow */
        .btn-primary {
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            box-shadow: 0 8px 30px rgba(122, 46, 58, 0.3);
            transform: translateY(-1px);
        }

        /* Step number pulse */
        .step-number {
            transition: transform 0.3s ease;
        }

        .step-number:hover {
            transform: scale(1.1);
        }

        /* Mobile menu */
        .mobile-menu {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s ease;
        }

        .mobile-menu.open {
            max-height: 500px;
        }
    </style>
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Michaela – Osobní stylistka",
        "description": "Osobní stylistka pro ženy 40+ s plus size postavou. Styling na míru, osobní nákupy a třídění šatníku.",
        "url": "https://stylovav50.cz",
        "image": "https://stylovav50.cz/assets/michaela-osobni-stylistka-hero.jpeg",
        "telephone": "+420775664567",
        "email": "stylovav50@seznam.cz",
        "address": {
            "@type": "PostalAddress",
            "addressCountry": "CZ"
        },
        "sameAs": [
            "https://www.instagram.com/stylovav50/"
        ],
        "priceRange": "$$",
        "openingHoursSpecification": {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
            "opens": "09:00",
            "closes": "18:00"
        }
    }
    </script>
</head>

